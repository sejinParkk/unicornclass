DB_HOST=localhost
DB_NAME=unicornclass
DB_USER=unicorn
DB_PASS=your_db_password

APP_DEBUG=false

# 알리고 SMS
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER=

# 카카오 소셜 로그인
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://yourdomain.com/auth/kakao/callback

# 네이버 소셜 로그인
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=https://yourdomain.com/auth/naver/callback

# Google Sheets 연동 (무료강의 수강 신청 기록)
GOOGLE_SHEETS_CREDENTIALS_PATH=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=수강신청
