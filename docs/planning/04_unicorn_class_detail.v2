<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>유니콘클래스 — 클래스 상세</title>
<link rel="stylesheet" href="./noto-sans.css" />
<link rel="stylesheet" href="./styles.css" />
<style>
/* 장바구니 아이콘 */
.cart-icon {
  position:relative; cursor:pointer; padding:4px 6px;
  display:flex; align-items:center; font-size:22px; color:#333;
  transition:color .15s;
}
.cart-icon:hover { color:#c0392b; }
.cart-badge {
  position:absolute; top:0; right:0;
  width:16px; height:16px; border-radius:50%;
  background:#c0392b; color:#fff;
  font-size:9px; font-weight:800;
  display:flex; align-items:center; justify-content:center;
  border:2px solid #fff;
}

/* 마이페이지 드롭다운 */
.mypage-wrap {
  position:relative; z-index:110;
}
.mypage-btn {
  display:flex; align-items:center; gap:6px; cursor:pointer;
  padding:4px 10px; border-radius:20px;
  border:1px solid #e0e0e0; background:#fff;
  font-size:13px; font-weight:600; color:#1a1a1a;
  transition:all .15s;
}
.mypage-btn:hover { border-color:#c0392b; color:#c0392b; }
.mypage-avatar {
  width:24px; height:24px; border-radius:50%;
  background:#c0392b; color:#fff;
  font-size:10px; font-weight:700;
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0;
}
.mypage-dropdown {
  position:absolute; top:100%; right:0;
  padding-top:8px; /* 시각적 간격은 padding으로 */
  background:transparent;
  display:none; z-index:120; min-width:160px;
}
.mypage-dropdown-inner {
  background:#fff; border:1px solid #e0e0e0;
  border-top:2px solid #c0392b;
  border-radius:0 0 6px 6px;
  box-shadow:0 8px 20px rgba(0,0,0,0.1);
  padding:4px 0;
}
.mypage-wrap:hover .mypage-dropdown { display:block; }
.mypage-dropdown a {
  display:block; padding:9px 16px;
  font-size:12.5px; color:#333; font-weight:400;
  border-bottom:1px solid #f5f5f5;
}
.mypage-dropdown a:last-child { border-bottom:none; }
.mypage-dropdown a:hover { background:#fff5f5; color:#c0392b; }
.mypage-dropdown .md-logout {
  color:#999; border-top:1px solid #eee; margin-top:2px;
}

/* ══════════════════════════════ 서브배너 */
#sub-banner {
  position:relative;
  background:linear-gradient(105deg,#0d0d0d 0%,#1a1a2e 60%,#0f2027 100%);
  padding:32px 32px 28px; overflow:hidden;
}
.sub-banner-bg {
  position:absolute; inset:0;
  background:linear-gradient(105deg, rgba(192,57,43,0.15) 0%, transparent 60%);
  pointer-events:none;
}
.sub-banner-label { font-size:11px; color:rgba(255,255,255,0.5); letter-spacing:2px; margin-bottom:6px; }
.sub-banner-title { font-size:28px; font-weight:900; color:#fff; letter-spacing:-1px; }

/* ══════════════════════════════ 클래스 탭 */
#class-tabs {
  background:#fff; border-bottom:2px solid #eee;
  padding:0 32px; display:flex;
}
.class-tab {
  padding:0 4px; height:50px; margin-right:24px;
  display:flex; align-items:center;
  font-size:14px; font-weight:600; color:#999; cursor:pointer;
  border-bottom:3px solid transparent; margin-bottom:-2px; transition:all .15s;
}
.class-tab.active { color:#c0392b; border-bottom-color:#c0392b; }

/* ══════════════════════════════ 브레드크럼 */
#breadcrumb {
  padding:10px 32px; font-size:12px; color:#aaa;
  border-bottom:1px solid #f5f5f5;
}
#breadcrumb span { color:#888; }
#breadcrumb span + span::before { content:' > '; color:#ccc; margin:0 4px; }
#breadcrumb span.cur { color:#555; font-weight:600; }

/* ══════════════════════════════ 상세 본문 2단 */
#detail-wrap {
  display:flex; gap:28px; padding:28px 32px 0; align-items:flex-start;
  position:relative;
}
/* 좌: 썸네일 + 탭 + 내용 */
.detail-left { flex:1; min-width:0; }
.detail-thumb {
  width:100%; aspect-ratio:16/9; border-radius:6px; overflow:hidden;
  background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460);
  margin-bottom:0;
}
/* 내용 탭 */
.detail-tabs {
  display:flex; border-bottom:2px solid #eee; margin-bottom:0;
  position:sticky; top:44px; z-index:90; background:#fff;
}
.detail-tab {
  flex:0 0 50%; text-align:center; justify-content:center;
  padding:0; height:44px; display:flex; align-items:center;
  font-size:13.5px; font-weight:600; color:#999; cursor:pointer;
  border-bottom:3px solid transparent; margin-bottom:-2px; transition:all .15s;
}
.detail-tab.active { color:#c0392b; border-bottom-color:#c0392b; }
.detail-content-area {
  min-height:320px; background:#f5f5f5;
  display:flex; align-items:center; justify-content:center;
  color:#aaa; font-size:12px; border-radius:0 0 4px 4px;
  padding:20px;
}

/* ══════════════════════════════ 우: 신청/결제 박스 */
.detail-right {
  width:260px; flex-shrink:0;  
}
.ann-host.detail-right {position:sticky !important; top:100px; align-self:flex-start;}
.detail-box {
  border:1px solid #e0e0e0; border-radius:8px;
  overflow:hidden; background:#fff;
  box-shadow:0 2px 12px rgba(0,0,0,0.08);
}
.detail-box-badges { padding:14px 16px 0; display:flex; gap:4px; }
.dbadge { font-size:10px; font-weight:700; padding:2px 7px; border-radius:2px; }
.db-hot { background:#fdecea; color:#c0392b; }
.db-new { background:#e8f5e9; color:#27ae60; }
.db-free { background:#e8f0ff; color:#3b5bdb; }
.db-premium { background:#f3e8ff; color:#8e44ad; }
.detail-box-title {
  padding:10px 16px 14px; font-size:15px; font-weight:800; color:#1a1a1a;
  line-height:1.45; border-bottom:1px solid #f0f0f0;
}

/* 찜하기 / 링크복사 */
.detail-box-actions {
  display:flex; gap:6px; padding:10px 16px;
  border-bottom:1px solid #f0f0f0;
}
.action-btn {
  display:flex; align-items:center; gap:4px;
  height:30px; padding:0 10px; border-radius:15px;
  border:1px solid #e0e0e0; background:#fff;
  font-size:12px; font-weight:600; color:#555; cursor:pointer;
  transition:all .15s;
}
.action-btn:hover { border-color:#c0392b; color:#c0392b; }
.action-btn.liked { border-color:#c0392b; color:#c0392b; background:#fff5f5; }
.action-btn .icon { font-size:14px; }

/* 탭 콘텐츠 영역 */
.detail-content-area { min-height:320px; background:#f5f5f5; display:flex; align-items:center; justify-content:center; color:#aaa; font-size:12px; border-radius:0 0 4px 4px; padding:20px; }
.detail-tab-content { display:none; }
.detail-tab-content.active { display:block; }
.detail-box-inst {
  padding:10px 16px; display:flex; justify-content:space-between;
  font-size:12.5px; color:#888; border-bottom:1px solid #f0f0f0;
}
.detail-box-inst span { color:#333; font-weight:600; }
.detail-box-date {
  padding:12px 16px; display:flex; align-items:center; gap:8px;
  border-bottom:1px solid #f0f0f0;
}
.date-icon { font-size:14px; }
.date-label { font-size:11.5px; color:#888; }
.date-val { font-size:12.5px; font-weight:700; color:#1a1a1a; margin-left:auto; }
.detail-box-timer {
  padding:10px 16px; background:#fff9f9;
  border-bottom:1px solid #f0f0f0;
  text-align:center; font-size:11.5px; color:#888;
}
.timer-val { font-size:17px; font-weight:900; color:#c0392b; letter-spacing:1px; margin-top:2px; }

/* 가격 (유료) */
.detail-box-price {
  padding:12px 16px; border-bottom:1px solid #f0f0f0;
}
.price-original { font-size:12px; color:#bbb; text-decoration:line-through; margin-bottom:2px; }
.price-discount { display:flex; align-items:baseline; gap:6px; }
.price-rate { font-size:14px; font-weight:900; color:#c0392b; }
.price-val { font-size:20px; font-weight:900; color:#1a1a1a; }

/* 신청/결제 버튼 */
.detail-box-btn { padding:14px 16px 16px; }
.btn-apply {
  width:100%; height:46px; border-radius:6px;
  background:#c0392b; color:#fff;
  font-size:15px; font-weight:800; cursor:pointer;
  transition:background .15s; border:none;
  margin-bottom:8px;
}
.btn-apply:hover { background:#a93226; }
.btn-apply.free { background:#3b5bdb; }
.btn-apply.free:hover { background:#2f4abf; }
.btn-cart {
  width:100%; height:42px; border-radius:6px;
  background:#fff; color:#c0392b;
  border:2px solid #c0392b;
  font-size:14px; font-weight:700; cursor:pointer;
  display:flex; align-items:center; justify-content:center; gap:6px;
  transition:all .15s;
}
.btn-cart:hover { background:#fff5f5; }
.btn-cart.added { background:#fdecea; color:#a93226; border-color:#a93226; }
.cart-note { font-size:11px; color:#aaa; text-align:center; margin-top:6px; }

/* 유효성 상태 박스 */
.state-box {
  margin:0 16px 14px; padding:10px 12px;
  border-radius:6px; font-size:12px; line-height:1.6;
  display:flex; gap:8px; align-items:flex-start;
}
.state-icon { font-size:14px; flex-shrink:0; margin-top:1px; }
.state-box.info   { background:#e8f0ff; color:#1a3a8a; border:1px solid #c5d5f5; }
.state-box.warn   { background:#fff8e1; color:#7a5800; border:1px solid #ffe082; }
.state-box.error  { background:#fdecea; color:#922b21; border:1px solid #f5c6c2; }
.state-box.success{ background:#e8f5e9; color:#1a6b2e; border:1px solid #c3e6cb; }

/* ══════════════════════════════ 강사 소개 (하단) */
#inst-intro {
  margin:32px 0 0; padding:20px;
  border:1px solid #eee; border-radius:8px;
  position:relative;
}
.inst-intro-head {
  font-size:14px; font-weight:800; color:#1a1a1a;
  margin-bottom:16px; padding-bottom:10px; border-bottom:1px solid #f0f0f0;
}
.inst-row {
  display:flex; align-items:center; justify-content:space-between;
}
.inst-profile { display:flex; align-items:center; gap:12px; }
.inst-avatar {
  width:40px; height:40px; border-radius:50%;
  background:linear-gradient(135deg,#888,#bbb);
  display:flex; align-items:center; justify-content:center;
  color:#fff; font-size:10px; font-weight:700; flex-shrink:0;
}
.inst-profile-name { font-size:14px; font-weight:800; }
.inst-profile-sub  { font-size:11.5px; color:#888; margin-top:1px; }
.inst-expand-btn {
  width:28px; height:28px; border-radius:50%; border:1px solid #ddd;
  display:flex; align-items:center; justify-content:center;
  font-size:16px; color:#888; cursor:pointer; transition:all .15s;
}
.inst-expand-btn:hover { border-color:#c0392b; color:#c0392b; }

/* ══════════════════════════════ 마케팅·면책 */
#terms-area {
  margin:40px 32px 0; position:relative;
}
.terms-block { margin-bottom:20px; }
.terms-title { font-size:13px; font-weight:800; color:#1a1a1a; margin-bottom:8px; }
.terms-body { font-size:12px; color:#666; line-height:1.8; background:#f9f9f9; padding:12px 14px; border-radius:6px; border:1px solid #eee; }

/* ══════════════════════════════ 섹션 구분선 */
.section-sep {
  margin:40px 32px 0;
  padding:12px 16px;
  background:#1a3a5c; color:#fff;
  border-radius:6px 6px 0 0;
  font-size:13px; font-weight:700; letter-spacing:0.5px;
  display:flex; align-items:center; gap:8px;
}
.section-sep .sep-badge {
  background:rgba(255,255,255,0.2); padding:2px 8px; border-radius:10px;
  font-size:10px; letter-spacing:1px;
}

/* ══════════════════════════════ 결제 프로세스 */
#payment-process {
  margin:0 32px 0; padding:24px;
  border:1px solid #d0dae8; border-top:none; border-radius:0 0 6px 6px;
  background:#fafcff; position:relative;
}
#free-process {
  margin:0 32px 0; padding:24px;
  border:1px solid #d0dae8; border-top:none; border-radius:0 0 6px 6px;
  background:#fafcff; position:relative;
}

/* 결제 플로우 스텝 */
.pay-steps {
  display:flex; align-items:center; gap:0; margin-bottom:28px;
}
.pay-step {
  flex:1; text-align:center; position:relative;
}
.pay-step-circle {
  width:32px; height:32px; border-radius:50%;
  background:#e0e0e0; color:#999; font-size:12px; font-weight:700;
  display:flex; align-items:center; justify-content:center;
  margin:0 auto 6px; position:relative; z-index:1;
}
.pay-step.done .pay-step-circle { background:#27ae60; color:#fff; }
.pay-step.active .pay-step-circle { background:#c0392b; color:#fff; box-shadow:0 0 0 4px rgba(192,57,43,0.15); }
.pay-step-label { font-size:11px; color:#aaa; font-weight:600; }
.pay-step.active .pay-step-label { color:#c0392b; font-weight:700; }
.pay-step.done .pay-step-label { color:#27ae60; }
.pay-step-line {
  position:absolute; top:16px; left:calc(50% + 16px); right:calc(-50% + 16px);
  height:2px; background:#e0e0e0; z-index:0;
}
.pay-step.done .pay-step-line { background:#27ae60; }

/* 결제 패널들 */
.pay-panel { display:none; }
.pay-panel.active { display:block; }
.free-panel { display:none; }
.free-panel.active { display:block; }
.pay-panel-title {
  font-size:14px; font-weight:800; color:#1a3a5c;
  margin-bottom:16px; padding-bottom:10px;
  border-bottom:2px solid #e8eef5;
}

/* 상품 확인 */
.order-product {
  display:flex; gap:14px; align-items:center;
  padding:14px; background:#fff; border:1px solid #e8e8e8; border-radius:6px;
  margin-bottom:14px;
}
.order-thumb {
  width:80px; height:45px; border-radius:4px; flex-shrink:0;
  background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460);
}
.order-info-title { font-size:13px; font-weight:700; color:#1a1a1a; margin-bottom:3px; }
.order-info-meta  { font-size:11.5px; color:#888; }
.order-price-row {
  display:flex; justify-content:space-between; align-items:center;
  padding:12px 14px; background:#fff; border:1px solid #e8e8e8; border-radius:6px;
  margin-bottom:6px; font-size:13px;
}
.order-price-row .label { color:#666; }
.order-price-row .val   { font-weight:700; color:#1a1a1a; }
.order-price-row.total  { background:#fff5f5; border-color:#f5c6c2; }
.order-price-row.total .val { color:#c0392b; font-size:15px; }

/* 결제수단 */
.pay-method-grid {
  display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-bottom:16px;
}
.pay-method-item {
  border:2px solid #e0e0e0; border-radius:6px; padding:12px 8px;
  text-align:center; cursor:pointer; transition:all .15s;
  background:#fff;
}
.pay-method-item:hover { border-color:#c0392b; }
.pay-method-item.selected { border-color:#c0392b; background:#fff5f5; }
.pay-method-icon { font-size:20px; margin-bottom:4px; }
.pay-method-label { font-size:11.5px; font-weight:600; color:#333; }
.pay-method-note  { font-size:10px; color:#999; margin-top:2px; }

/* PG 미정 안내 */
.pg-notice {
  padding:10px 14px; background:#fff8e1;
  border:1px solid #ffe082; border-radius:6px;
  font-size:11.5px; color:#7a5800; line-height:1.6; margin-bottom:16px;
}

/* 입력 필드 */
.pay-field { margin-bottom:12px; }
.pay-field label { display:block; font-size:12px; font-weight:700; color:#555; margin-bottom:4px; }
.pay-field input, .pay-field select {
  width:100%; height:38px; border:1px solid #ddd; border-radius:5px;
  padding:0 12px; font-size:13px; font-family:inherit; color:#333; outline:none;
  transition:border-color .15s; background:#fff;
}
.pay-field input:focus, .pay-field select:focus { border-color:#c0392b; }
.pay-field-row { display:flex; gap:8px; }
.pay-field-row .pay-field { flex:1; }

/* 약관 동의 */
.pay-agree { margin-bottom:16px; }
.agree-all {
  padding:10px 14px; background:#f5f5f5; border-radius:6px;
  margin-bottom:8px; display:flex; align-items:center; gap:8px;
  font-size:13px; font-weight:700; cursor:pointer;
}
.agree-item {
  padding:6px 14px; display:flex; align-items:center; gap:8px;
  font-size:12px; color:#555; cursor:pointer;
}
.agree-item a { color:#c0392b; text-decoration:underline; margin-left:4px; }
input[type=checkbox] { accent-color:#c0392b; width:14px; height:14px; cursor:pointer; }

/* 완료/실패 화면 */
.pay-result {
  text-align:center; padding:32px 20px;
}
.pay-result-icon { font-size:48px; margin-bottom:16px; }
.pay-result-title { font-size:18px; font-weight:900; margin-bottom:8px; }
.pay-result-desc  { font-size:13px; color:#888; line-height:1.7; margin-bottom:20px; }
.pay-result-detail {
  background:#f9f9f9; border:1px solid #eee; border-radius:6px;
  padding:14px 16px; text-align:left; margin-bottom:20px;
}
.pay-result-row {
  display:flex; justify-content:space-between;
  font-size:12.5px; padding:4px 0; border-bottom:1px solid #f0f0f0;
}
.pay-result-row:last-child { border-bottom:none; }
.pay-result-row .rl { color:#888; }
.pay-result-row .rv { font-weight:700; color:#1a1a1a; }

/* 유효성 케이스 섹션 */
#validation-cases {
  margin:0 32px 0; padding:24px;
  border:1px solid #d0dae8; border-top:none;
  background:#fff; position:relative;
}
.val-case-grid {
  display:grid; grid-template-columns:repeat(2,1fr); gap:12px;
}
.val-case {
  border:1px solid #e0e0e0; border-radius:6px; overflow:hidden;
  background:#fff;
}
.val-case-head {
  padding:8px 14px; font-size:11px; font-weight:700; letter-spacing:0.5px;
  border-bottom:1px solid #eee;
}
.val-case.type-info .val-case-head   { background:#e8f0ff; color:#1a3a8a; }
.val-case.type-warn .val-case-head   { background:#fff8e1; color:#7a5800; }
.val-case.type-error .val-case-head  { background:#fdecea; color:#922b21; }
.val-case.type-success .val-case-head{ background:#e8f5e9; color:#1a6b2e; }
.val-case-body { padding:10px 14px; }
.val-case-btn {
  display:block; width:100%; height:36px;
  border-radius:5px; font-size:13px; font-weight:700;
  cursor:pointer; border:none; margin-bottom:8px;
}
.val-case-btn.red   { background:#c0392b; color:#fff; }
.val-case-btn.blue  { background:#3b5bdb; color:#fff; }
.val-case-btn.gray  { background:#e0e0e0; color:#999; cursor:not-allowed; }
.val-case-msg { font-size:11.5px; color:#666; line-height:1.6; }
.val-case-state {
  margin-top:8px; padding:8px 10px; border-radius:4px;
  font-size:11.5px; line-height:1.5;
}
.val-case-state.info   { background:#e8f0ff; color:#1a3a8a; }
.val-case-state.warn   { background:#fff8e1; color:#7a5800; }
.val-case-state.error  { background:#fdecea; color:#922b21; }
.val-case-state.success{ background:#e8f5e9; color:#1a6b2e; }

/* 결제 네비 버튼 */
.pay-nav { display:flex; gap:10px; margin-top:20px; pointer-events:auto;}
.pay-nav-btn {
  flex:1; height:42px; border-radius:6px; font-size:14px; font-weight:700;
  cursor:pointer; border:none; transition:all .15s;
}
.pay-nav-btn.prev { background:#f0f0f0; color:#555; }
.pay-nav-btn.prev:hover { background:#e0e0e0; }
.pay-nav-btn.next { background:#c0392b; color:#fff; }
.pay-nav-btn.next:hover { background:#a93226; }
.pay-nav-btn.free-next { background:#3b5bdb; color:#fff; }
.pay-nav-btn.free-next:hover { background:#2f4abf; }
</style>
</head>
<body>

<!-- ── 기획서 헤더 ── -->
<div class="doc-header">
  <div>
    <div class="doc-proj">Project — 유니콘클래스 기획서 v2.0</div>
    <div class="doc-title">클래스 상세</div>
  </div>
</div>

<!-- ══ 탭 네비게이션 ══ -->
<nav class="tab-nav">
  <div class="tab-nav-inner">
    <div class="tab-btn" onclick="location.href='./01_unicorn_main.html'">메인</div>
