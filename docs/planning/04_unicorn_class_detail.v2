<script>
// ── 찜하기 토글 ──
function toggleLike(btn) {
  const liked = btn.classList.toggle('liked');
  btn.querySelector('.icon').textContent = liked ? '❤️' : '🤍';
  btn.childNodes[1].textContent = liked ? ' 찜완료' : ' 찜하기';
}

// ── 링크복사 ──
function copyLink() {
  const ta = document.createElement('textarea');
  ta.value = window.location.href;
  ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0;';
  document.body.appendChild(ta);
  ta.focus();
  ta.select();
  try {
    document.execCommand('copy');
    showCopyToast('🔗 링크가 복사되었습니다!');
  } catch(e) {
    showCopyToast('링크 복사에 실패했습니다.');
  }
  document.body.removeChild(ta);
}
function showCopyToast(msg) {
  let toast = document.getElementById('copy-toast');
  if (!toast) {
    toast = document.createElement('div');
    toast.id = 'copy-toast';
    toast.style.cssText = [
      'position:fixed','bottom:32px','left:50%',
      'transform:translateX(-50%)',
      'background:#1a3a5c','color:#fff',
      'padding:10px 20px','border-radius:6px',
      'font-size:13px','font-weight:600',
      'z-index:9999','box-shadow:0 4px 12px rgba(0,0,0,.25)',
      'opacity:0','transition:opacity .25s','pointer-events:none'
    ].join(';');
    document.body.appendChild(toast);
  }
  toast.textContent = msg;
  toast.style.opacity = '1';
  clearTimeout(toast._t);
  toast._t = setTimeout(() => { toast.style.opacity = '0'; }, 2200);
}

// ── 탭 클릭 → 해당 섹션으로 스크롤 ──
function scrollToSection(id) {
  const el = document.getElementById(id);
  if (!el) return;
  const tabsEl = document.querySelector('.detail-tabs');
  const tabsH  = tabsEl ? tabsEl.offsetHeight : 0;
  const docH   = document.querySelector('.doc-header')?.offsetHeight || 0;
  const top = window.scrollY + el.getBoundingClientRect().top - docH - tabsH - 4;
  window.scrollTo({ top, behavior: 'smooth' });
}

// ── 스크롤 시 탭 active 연동 (scroll 이벤트) ──
document.addEventListener('DOMContentLoaded', () => {
  const tabs = document.querySelectorAll('.detail-tab');

  function updateActiveTab() {
    const docH  = document.querySelector('.doc-header')?.offsetHeight || 44;
    const tabsH = document.querySelector('.detail-tabs')?.offsetHeight || 44;
    const offset = docH + tabsH + 8; // sticky 헤더 높이 + 여유

    const sClass = document.getElementById('section-class');
    const sInst  = document.getElementById('section-inst');
    if (!sClass || !sInst) return;

    const instTop = sInst.getBoundingClientRect().top;

    // 강사소개 섹션 상단이 offset 아래로 내려가면(= 아직 안 도달) 클래스소개 active
    // 강사소개 섹션 상단이 offset 위로 올라오면(= 진입) 강사소개 active
    if (instTop <= offset) {
      tabs.forEach(t => t.classList.remove('active'));
      tabs[1]?.classList.add('active');
    } else {
      tabs.forEach(t => t.classList.remove('active'));
      tabs[0]?.classList.add('active');
    }
  }

  window.addEventListener('scroll', updateActiveTab, { passive: true });
  updateActiveTab(); // 초기 실행
});

// ── 장바구니 토글 ──
function toggleCart(btn) {
  const added = btn.classList.toggle('added');
  btn.innerHTML = added
    ? '<span>✅</span> 장바구니 담김'
    : '<span>🛒</span> 장바구니 담기';
}

// ── 무료 신청 스텝 이동 ──
function goFreeStep(n) {
  document.querySelectorAll('.free-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('free-panel-' + n)?.classList.add('active');
  document.querySelectorAll('#free-steps .pay-step').forEach((s, i) => {
    s.classList.remove('active','done');
    if (i + 1 < n) s.classList.add('done');
    if (i + 1 === n) s.classList.add('active');
  });
  const fp = document.getElementById('free-process');
  if (fp) fp.scrollIntoView({ behavior:'smooth', block:'start' });
}

// ── 무료 전체 동의 토글 ──
function toggleFreeAll(chk) {
  document.querySelectorAll('.fchk-item').forEach(c => c.checked = chk.checked);
}


let currentPayStep = 1;
function goPayStep(n) {
  document.querySelectorAll('.pay-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('pay-panel-' + n)?.classList.add('active');
  document.querySelectorAll('.pay-step').forEach((s, i) => {
    s.classList.remove('active','done');
    if (i + 1 < n) s.classList.add('done');
    if (i + 1 === n) s.classList.add('active');
  });
  currentPayStep = n;
  const pp = document.getElementById('payment-process');
  if (pp) pp.scrollIntoView({ behavior:'smooth', block:'start' });
}

// ── 결제 수단 선택 ──
function selectMethod(el) {
  document.querySelectorAll('.pay-method-item').forEach(m => m.classList.remove('selected'));
  el.classList.add('selected');
}

// ── 전체 동의 토글 ──
function toggleAll(chk) {
  document.querySelectorAll('.chk-item').forEach(c => c.checked = chk.checked);
}

// ── ann 양방향 연동 ──
function activateAnn(id) {
  const bubble = document.querySelector(`.ann-bubble[data-ann="${id}"]`);
  const isActive = bubble && bubble.classList.contains('active');
  document.querySelectorAll('.ann-bubble[data-ann]').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.desc-num[data-desc]').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.desc-item.active').forEach(el => el.classList.remove('active'));
  if (isActive) return;
  if (bubble) {
    bubble.classList.add('active');
    const annHost = bubble.closest('.ann-host');
    if (annHost) {
      const rect = annHost.getBoundingClientRect();
      window.scrollTo({ top: window.scrollY + rect.top - 150, behavior:'smooth' });
      annHost.style.outline = '2.5px solid #c0392b';
      annHost.style.outlineOffset = '4px';
      annHost.style.borderRadius = '4px';
      setTimeout(() => { annHost.style.outline = ''; annHost.style.outlineOffset = ''; }, 1800);
    } else {
      const el = document.getElementById(bubble.dataset.scroll);
      if (el) window.scrollTo({ top: window.scrollY + el.getBoundingClientRect().top - 70, behavior:'smooth' });
    }
  }
  const descNum = document.querySelector(`.desc-num[data-desc="${id}"]`);
  if (descNum) {
    descNum.classList.add('active');
    const item = descNum.closest('.desc-item');
    if (item) {
      item.classList.add('active');
      const panel = item.closest('.desc-panel');
      if (panel) panel.scrollTo({ top: item.offsetTop - (panel.querySelector('.desc-panel-head')?.offsetHeight || 0) - 12, behavior:'smooth' });
    }
  }
}

// ── 오픈채팅 최초 클릭 시 읽음(is_read) 처리 ──
function markOpenchatRead(el) {
  // 이미 읽음 처리된 경우 API 재호출 안 함
  if (el.dataset.read === '1') return;
  el.dataset.read = '1';
  // 실제 구현 시: fetch('/api/openchat-read', { method:'POST', body: JSON.stringify({ class_idx: CLASS_IDX }) })
  // lc_openchat_log.is_read = 1 SET (최초 1회만)
  console.log('[읽음 처리] 오픈채팅 클릭 기록 — is_read = 1');
}
</script>
</body>
