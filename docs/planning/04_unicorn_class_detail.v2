  <!-- ════════════════════════════════════════
       유효성 케이스 섹션
  ════════════════════════════════════════ -->
  <div class="section-sep" style="margin-top:40px;">
    <span>⚠</span> 신청 / 결제 유효성 케이스
    <span class="sep-badge">VALIDATION</span>
  </div>

  <div id="validation-cases" class="ann-host">
    <div class="ann" style="top:5px;">
      <div class="ann-bubble" data-ann="cd-9" data-scroll="validation-cases" onclick="activateAnn('cd-9')">9</div>
    </div>

    <div class="val-case-grid">

      <!-- 비회원 -->
      <div class="val-case type-warn">
        <div class="val-case-head">CASE 1 — 비회원 접근 (무료 · 유료 공통)</div>
        <div class="val-case-body">
          <button class="val-case-btn red" disabled style="cursor:not-allowed;opacity:.6">무료강의 신청하기</button>
          <div class="val-case-state warn">⚠ 로그인 후 이용 가능합니다.<br><a href="#" style="color:#7a5800;font-weight:700;text-decoration:underline;">로그인 하러 가기 →</a></div>
          <div class="val-case-msg" style="margin-top:8px;">
            <strong>무료강의 · 유료강의 모두 로그인 필수</strong><br>
            버튼 클릭 시 로그인 페이지 이동 (returnUrl 포함)<br>
            무료강의 신청 완료 시 회원 정보를 구글 시트에 저장하기 위해 로그인 필수
          </div>
        </div>
      </div>

      <!-- 이미 신청 완료 (무료) -->
      <div class="val-case type-success">
        <div class="val-case-head">CASE 2 — 이미 신청 완료 (무료)</div>
        <div class="val-case-body">
          <button class="val-case-btn gray">신청 완료</button>
          <div class="val-case-state success">✅ 이미 신청하셨습니다.<br>강의 당일 카카오톡으로 링크가 전송됩니다.</div>
          <div class="val-case-msg" style="margin-top:8px;">버튼 비활성화 + 완료 상태 표시<br>마이페이지에서 확인 가능</div>
        </div>
      </div>

      <!-- 이미 구매 완료 (유료) -->
      <div class="val-case type-success">
        <div class="val-case-head">CASE 3 — 이미 구매 완료 (유료)</div>
        <div class="val-case-body">
          <button class="val-case-btn gray">구매 완료</button>
          <div class="val-case-state success">✅ 이미 구매하셨습니다.<br>마이페이지 > 내 강의에서 수강할 수 있습니다.</div>
          <div class="val-case-msg" style="margin-top:8px;">버튼 비활성화<br>'수강하러 가기' 버튼으로 교체 옵션</div>
        </div>
      </div>

      <!-- 신청 기간 전 -->
      <div class="val-case type-info">
        <div class="val-case-head">CASE 4 — 신청 기간 전</div>
        <div class="val-case-body">
          <button class="val-case-btn gray">신청 대기중</button>
          <div class="val-case-state info">ℹ 신청 기간이 아직 시작되지 않았습니다.<br>신청 시작: 2026.04.01 10:00</div>
          <div class="val-case-msg" style="margin-top:8px;">버튼 비활성화 + 시작 일시 표시<br>오픈 알림 신청 기능 추가 검토</div>
        </div>
      </div>

      <!-- 신청 기간 종료 -->
      <div class="val-case type-error">
        <div class="val-case-head">CASE 5 — 신청 기간 종료</div>
        <div class="val-case-body">
          <button class="val-case-btn gray">신청 마감</button>
          <div class="val-case-state error">✖ 신청이 마감되었습니다.<br>다음 강의 일정을 확인해 보세요.</div>
          <div class="val-case-msg" style="margin-top:8px;">버튼 비활성화<br>'다음 강의 보러 가기' 링크 제공</div>
        </div>
      </div>

      <!-- 결제 실패 -->
      <div class="val-case type-error">
        <div class="val-case-head">CASE 6 — 결제 실패 (유료)</div>
        <div class="val-case-body">
          <button class="val-case-btn red">결제하기</button>
          <div class="val-case-state error">✖ 결제에 실패했습니다.<br>카드 정보를 확인하거나 다른 수단을 이용해 주세요.</div>
          <div class="val-case-msg" style="margin-top:8px;">PG사 응답 코드별 메시지 분기<br>재시도 버튼 제공</div>
        </div>
      </div>

      <!-- 서버 오류 -->
      <div class="val-case type-warn">
        <div class="val-case-head">CASE 7 — 서버 / 네트워크 오류</div>
        <div class="val-case-body">
          <button class="val-case-btn gray">처리중...</button>
          <div class="val-case-state warn">⚠ 일시적인 오류가 발생했습니다.<br>잠시 후 다시 시도해 주세요.</div>
          <div class="val-case-msg" style="margin-top:8px;">중복 결제 방지: 처리 중 버튼 비활성화<br>오류 로그 서버 기록</div>
        </div>
      </div>

